                <mxCell id="138" value="Ogni UTENTE può creare molti POST&lt;div&gt;Ogni UTENTE può inserire molti COMMENTI&lt;/div&gt;&lt;div&gt;Ogni UTENTE può mettere molti LIKES&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ogni POST può contenere molti MEDIA&lt;/div&gt;&lt;div&gt;Ogni POST può avere molti COMMENTI&lt;/div&gt;&lt;div&gt;Ogni POST può avere molti LIKES&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;La tabella LIKES è quella che mette in relazione UTENTI e POSTS&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;La tabella MEDIA_POST è ponte tra POSTS e MEDIA percho ogni POST può contenere più MEDIA e ogni MEDIA può essere presente in molti POSTS&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
                    <mxGeometry x="-240" y="970" width="840" height="290" as="geometry"/>
                </mxCell>
